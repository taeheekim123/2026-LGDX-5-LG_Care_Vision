  "required_official_sources": ["product_image", "owners_manual", "official_faq"],
  "parts": [
    {
      "tag": "air_conditioner.body",
      "display_name": "Air conditioner body",
      "user_accessible": true
    },
    {
      "tag": "air_conditioner.front_panel",
      "display_name": "Front panel",
      "user_accessible": true
    },
    {
      "tag": "air_conditioner.filter.mesh_filter",
      "display_name": "Dust filter",
      "user_accessible": true
    },
    {
      "tag": "air_conditioner.filter_slot",
      "display_name": "Filter slot",
      "user_accessible": true
    },
    {
      "tag": "air_conditioner.air_outlet",
      "display_name": "Air outlet",
      "user_accessible": true
    },
    {
      "tag": "air_conditioner.power_button",
      "display_name": "Power button",
      "user_accessible": true
    }
  ],
  "allowed_actions": [
    "power_off",
    "open_front_panel",
    "remove_filter",
    "wash_filter_with_water",
    "dry_filter_in_shade",
