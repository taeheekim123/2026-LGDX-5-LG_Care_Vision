      "duration_sec_shortform": 4,
      "duration_sec_manual": 6,
      "camera": "final_front_wide",
      "parts": ["air_conditioner.front_panel", "air_conditioner.body"],
      "action": "close_front_panel",
      "highlight": {
        "type": "outline",
        "target_part": "air_conditioner.front_panel",
        "text_template_id": "aircon_close_panel"
      },
      "subtitle_template_id": "aircon_close_panel",
      "tts_template_id": "aircon_close_panel"
    }
