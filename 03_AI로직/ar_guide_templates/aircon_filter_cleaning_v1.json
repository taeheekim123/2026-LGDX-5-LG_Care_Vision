  "forbidden_generation_notes": [
    "Do not show PCB, refrigerant pipe, compressor, fan motor internals, or internal wiring.",
    "Do not invent labels, buttons, logos, or model text not found in official assets.",
    "Keep clean reference separate from annotated overlay."
  ],
  "scene_steps": [
    {
