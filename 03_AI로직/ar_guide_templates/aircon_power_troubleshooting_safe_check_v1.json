    "power_indicator_close_up",
    "outlet_safe_distance",
    "breaker_panel_safe_distance",
    "service_request_card"
  ],
  "highlight_rules": [
    "safety_stop_icon",
    "power_button_outline",
    "power_indicator_box",
    "plug_connection_checkmark",
    "breaker_status_box",
    "expert_as_cta"
  ],
  "forbidden_generation_notes": [
    "Do not show opened covers, PCB, compressor, refrigerant pipe, fan motor internals, or wiring repair.",
