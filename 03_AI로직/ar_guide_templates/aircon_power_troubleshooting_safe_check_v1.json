    {
      "tag": "air_conditioner.power_button",
      "display_name": "Power button",
      "user_accessible": true
    },
    {
      "tag": "air_conditioner.power_indicator",
      "display_name": "Power indicator or display",
      "user_accessible": true
    },
    {
      "tag": "home.accessible_power_plug_or_outlet",
      "display_name": "Accessible plug or wall outlet",
      "user_accessible": true
    },
    {
      "tag": "home.circuit_breaker_panel",
      "display_name": "Home circuit breaker panel",
      "user_accessible": true
    }
  ],
  "allowed_actions": [
    "stop_if_high_risk_signal",
    "turn_off_unit",
    "check_remote_display_or_battery",
    "check_visible_power_indicator",
